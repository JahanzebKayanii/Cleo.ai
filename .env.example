# ── Database ──────────────────────────────────────────────
POSTGRES_USER=cleo
POSTGRES_PASSWORD=cleo_pass
POSTGRES_DB=cleo_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Qdrant ────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=cleo_docs

# ── Anthropic (Claude) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Voyage AI (Embeddings) ────────────────────────────────
VOYAGE_API_KEY=pa-...

# ── Twilio ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# ── Deepgram ──────────────────────────────────────────────
DEEPGRAM_API_KEY=...

# ── ElevenLabs (TTS) ──────────────────────────────────────
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...

# ── App ───────────────────────────────────────────────────
APP_ENV=development
BASE_URL=http://localhost:8000
