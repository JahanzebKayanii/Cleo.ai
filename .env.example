# ── Database ───────────────────────────────────────────────
# Option A: Supabase (production) — paste the direct connection string
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Option B: Local Docker (development) — uses individual vars below
# POSTGRES_USER=cleo
# POSTGRES_PASSWORD=cleo_pass
# POSTGRES_DB=cleo_db
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432

# ── Qdrant ─────────────────────────────────────────────────
# Option A: Qdrant Cloud (production)
QDRANT_URL=https://[cluster-id].us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=...
QDRANT_COLLECTION=cleo_docs

# Option B: Local Docker (development)
# QDRANT_HOST=qdrant
# QDRANT_PORT=6333
# QDRANT_COLLECTION=cleo_docs

# ── Anthropic (Claude) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Voyage AI (Embeddings) ─────────────────────────────────
VOYAGE_API_KEY=pa-...

# ── Twilio ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# ── Deepgram ───────────────────────────────────────────────
DEEPGRAM_API_KEY=...

# ── ElevenLabs (TTS) ───────────────────────────────────────
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...

# ── App ────────────────────────────────────────────────────
APP_ENV=production
BASE_URL=https://your-ec2-ip-or-domain.com
